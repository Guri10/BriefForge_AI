# Copy to `.env` at the repo root and replace placeholders. Real `.env` is gitignored.

# --- mcp-news-server (Docker Compose substitutes into container only) ---
NEWSAPI_API_KEY=your_newsapi_api_key_here

# --- agent-service ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# --- web (Vite: baked in at build via Docker build arg or apps/web .env) ---
VITE_AGENT_BASE_URL=http://localhost:8000

# --- Optional: local scripts / docs (not passed by docker-compose.yml to every service) ---
AGENT_SERVICE_URL=http://localhost:8000
MCP_NEWS_SERVER_URL=http://localhost:8001
